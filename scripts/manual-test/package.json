{
  "name": "@webox/manual-test",
  "version": "0.1.0",
  "description": "Sprint 20 smoke tests for Webox TUI via tuistory (Playwright-for-terminals).",
  "private": true,
  "type": "module",
  "scripts": {
    "smoke": "node --experimental-strip-types --no-warnings smoke.ts",
    "smoke:bento": "node --experimental-strip-types --no-warnings scenarios/bento-modes.ts",
    "smoke:help": "node --experimental-strip-types --no-warnings scenarios/help-overlay.ts",
    "smoke:catalog": "node --experimental-strip-types --no-warnings scenarios/provider-catalog.ts",
    "smoke:mouse": "node --experimental-strip-types --no-warnings scenarios/mouse-click.ts",
    "smoke:detail": "node --experimental-strip-types --no-warnings scenarios/project-detail.ts"
  },
  "dependencies": {
    "tuistory": "^0.8.0"
  }
}
