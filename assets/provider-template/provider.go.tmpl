// providerName is the registered type token shared with
// `config.Profile.Type` and the operator-facing docs. Exported as a
// constant so wizard / doctor never carry stringly-typed literals.
const providerName = "{{.Name}}"

// ErrNotImplemented is the placeholder sentinel every generated
// HostingProvider method returns until the contributor wires the
// real {{.DisplayName}} transport. Tests check that callers branch
// on it via [errors.Is] rather than message equality so swapping
// the stub for the real implementation does not break the wizard
// flow halfway through implementation.
var ErrNotImplemented = errors.New("{{.Name}}: method not implemented yet — see docs/contributing/PROVIDER.md")

// Provider is the {{.DisplayName}} HostingProvider implementation.
// It is constructed via [New] (registered with providers.Register in
// init()); business logic NEVER instantiates it directly.
//
// Replace the `// TODO` placeholders one by one — start with
// [Provider.CheckStatus] (cheapest probe), then [Provider.ListSubdomains]
// (read-only), then the mutating methods in the order the wizard
// exercises them (CreateSubdomain → SetupSSL → CreateDatabase →
// RestartNodeApp). Idempotent Remove* methods come last and reuse the
// same parsers as their Create counterparts.
type Provider struct {
	cfg providers.ProviderConfig
}

// New is the [providers.Factory] registered under "{{.Name}}".
// The registry already validated shared invariants (alias / host /
// user / port / Properties non-nil); the constructor only needs to
// run adapter-specific checks (panel URL, token presence, etc.).
//
// TODO: parse [cfg.Properties] into a typed struct (mirror
// `providers/smallhost/config.go`'s [parseProperties]).
func New(cfg providers.ProviderConfig) (providers.HostingProvider, error) {
	if cfg.Type != providerName {
		return nil, fmt.Errorf("%w: {{.PackageName}} factory invoked with type %q", providers.ErrInvalidProviderConfig, cfg.Type)
	}
	return &Provider{cfg: cfg}, nil
}

// Name satisfies [providers.HostingProvider] — return the registered
// type rather than the alias so logs survive alias renames.
func (p *Provider) Name() string { return providerName }

